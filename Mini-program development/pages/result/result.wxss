.custom-navigation {
  position: fixed;
  z-index: 100;
  top: 0;
  right: 0;
  left: 0;
  box-sizing: border-box;
  border-bottom: 2rpx solid #e7eaec;
  background: #ffffff;
}

.custom-navigation__bar {
  position: relative;
  display: flex;
  align-items: center;
  width: 100%;
}

.custom-navigation__title {
  position: absolute;
  top: 50%;
  left: 50%;
  color: #20262d;
  font-size: 28rpx;
  font-weight: 650;
  line-height: 1;
  transform: translate(-50%, -50%);
}

.navigation-back {
  position: absolute;
  top: 50%;
  left: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 72rpx;
  height: 72rpx;
  margin: 0;
  padding: 0;
  border-radius: 8rpx;
  background: transparent;
  line-height: 1;
  transform: translateY(-50%);
}

.navigation-back__icon {
  width: 20rpx;
  height: 20rpx;
  margin-left: 8rpx;
  border-bottom: 4rpx solid #20262d;
  border-left: 4rpx solid #20262d;
  transform: rotate(45deg);
}

.navigation-back--pressed {
  background: #eef1f3;
}

.navigation-placeholder {
  width: 100%;
}

.result-page {
  min-height: auto;
  padding-bottom: 64rpx;
}

.result-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 10rpx 2rpx 22rpx;
}

.result-title,
.result-id {
  display: block;
}

.result-title {
  color: #20262d;
  font-size: 38rpx;
  font-weight: 750;
  line-height: 1.3;
}

.result-id {
  margin-top: 6rpx;
  color: #7b848b;
  font-size: 21rpx;
}

.result-status {
  padding: 10rpx 16rpx;
  border-radius: 8rpx;
  background: #e5f5f3;
  color: #247d79;
  font-size: 22rpx;
  font-weight: 650;
}

.stats-grid {
  display: flex;
  align-items: stretch;
  border: 2rpx solid #e0e5e8;
  border-radius: 16rpx;
  background: #ffffff;
}

.stat-item {
  display: flex;
  flex: 1 1 0;
  align-items: center;
  flex-direction: column;
  justify-content: center;
  width: 0;
  min-width: 0;
  height: 132rpx;
  border-right: 2rpx solid #e8ebed;
}

.stat-item:last-child {
  border-right: 0;
}

.stat-value {
  max-width: 100%;
  overflow: hidden;
  color: #252d34;
  font-size: 30rpx;
  font-weight: 750;
  line-height: 1.3;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.stat-label {
  margin-top: 8rpx;
  color: #778088;
  font-size: 21rpx;
}

.result-section {
  margin-top: 24rpx;
  border: 2rpx solid #e0e5e8;
  border-radius: 16rpx;
  background: #ffffff;
}

.image-section {
  overflow: hidden;
}

.result-tabs {
  display: flex;
  align-items: stretch;
  gap: 8rpx;
  padding: 8rpx;
  border-bottom: 2rpx solid #e7eaec;
  background: #f0f2f4;
}

.result-tab {
  display: flex;
  flex: 1 1 0;
  align-items: center;
  justify-content: center;
  width: 0;
  min-width: 0;
  height: 68rpx;
  margin: 0;
  padding: 0;
  border-radius: 8rpx;
  background: transparent;
  color: #606a72;
  font-size: 25rpx;
  font-weight: 650;
  line-height: 1.2;
}

.result-tab--active {
  background: #ffffff;
  color: #c74651;
  box-shadow: 0 2rpx 6rpx rgba(34, 43, 51, 0.1);
}

.pattern-preview {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 900rpx;
  background: #e9ecee;
}

.pattern-image {
  width: 100%;
  height: 100%;
}

.image-loading {
  position: absolute;
  top: 50%;
  left: 50%;
  padding: 14rpx 20rpx;
  border-radius: 8rpx;
  background: rgba(32, 38, 45, 0.82);
  color: #ffffff;
  font-size: 22rpx;
  transform: translate(-50%, -50%);
}

.action-grid {
  display: flex;
  align-items: stretch;
  gap: 16rpx;
  margin-top: 24rpx;
}

.action-grid .primary-button,
.action-grid .secondary-button {
  flex: 1 1 0;
  width: 0;
  min-width: 0;
  margin: 0;
  padding: 0 12rpx;
  line-height: 1.2;
}

.palette-section {
  padding: 26rpx;
}

.palette-heading {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.palette-heading .section-title {
  margin-bottom: 0;
}

.palette-total {
  color: #7a838a;
  font-size: 22rpx;
}

.palette-table {
  margin-top: 20rpx;
  border-top: 2rpx solid #e8ebed;
}

.palette-row {
  display: flex;
  align-items: center;
  min-height: 92rpx;
  border-bottom: 2rpx solid #edf0f2;
}

.palette-row:last-child {
  border-bottom: 0;
}

.color-swatch {
  flex: 0 0 auto;
  width: 54rpx;
  height: 54rpx;
  border: 2rpx solid rgba(32, 38, 45, 0.14);
  border-radius: 8rpx;
}

.color-main,
.color-count {
  display: flex;
  flex-direction: column;
}

.color-main {
  flex: 1;
  min-width: 0;
  margin-left: 18rpx;
}

.color-code {
  color: #283139;
  font-size: 27rpx;
  font-weight: 750;
}

.color-name {
  overflow: hidden;
  margin-top: 2rpx;
  color: #7b848b;
  font-size: 20rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.color-count {
  flex: 0 0 auto;
  align-items: flex-end;
  color: #343e46;
  font-size: 24rpx;
  font-variant-numeric: tabular-nums;
}

.color-share {
  margin-top: 2rpx;
  color: #858d94;
  font-size: 20rpx;
}

.back-button {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 82rpx;
  margin: 24rpx 0 0;
  padding: 0;
  border-radius: 12rpx;
  background: transparent;
  color: #59636b;
  font-size: 25rpx;
  line-height: 1.2;
}

.empty-result {
  box-sizing: border-box;
  display: flex;
  align-items: center;
  flex-direction: column;
  justify-content: center;
  min-height: 100vh;
  padding: 40rpx;
}

.empty-result__title {
  margin-bottom: 32rpx;
  color: #59636b;
  font-size: 30rpx;
  font-weight: 650;
}
