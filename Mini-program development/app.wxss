page {
  min-height: 100%;
  background: #f4f6f8;
  color: #20262d;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", "Microsoft YaHei", sans-serif;
}

button {
  box-sizing: border-box;
  letter-spacing: 0;
}

button::after {
  border: 0;
}

.page-shell {
  box-sizing: border-box;
  width: 100%;
  max-width: 960rpx;
  min-height: 100vh;
  margin: 0 auto;
  padding: 28rpx 28rpx 48rpx;
}

.section-title {
  display: block;
  margin-bottom: 20rpx;
  color: #20262d;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 1.4;
}

.primary-button,
.secondary-button {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 92rpx;
  border-radius: 12rpx;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 92rpx;
}

.primary-button {
  background: #df5965;
  color: #ffffff;
}

.primary-button[disabled] {
  background: #cdd2d7;
  color: #ffffff;
}

.secondary-button {
  border: 2rpx solid #cfd5da;
  background: #ffffff;
  color: #29333c;
}
